# Blockchain Deployment Config
# Copy to .env and fill in your values

# ── Deployer ──────────────────────────────────────────────────────────
# Your wallet private key (NEVER commit this)
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ── Field Nine Wallets ────────────────────────────────────────────────
# Gnosis Safe address (set up at https://app.safe.global)
# This receives initial 10M KAUS and Genesis payments
TREASURY_ADDRESS=0x_YOUR_GNOSIS_SAFE_ADDRESS

# Fee collector wallet (receives 0.1% from all trades)
# Can be same as treasury or separate hot wallet
FEE_COLLECTOR_ADDRESS=0x_YOUR_FEE_WALLET_ADDRESS

# ── API Keys ──────────────────────────────────────────────────────────
# Polygonscan API key for contract verification
# Get at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── After Deployment ──────────────────────────────────────────────────
# Add these to K-Arena Vercel env vars:
NEXT_PUBLIC_KAUS_CONTRACT=0x_DEPLOYED_CONTRACT_ADDRESS
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_POLYGON_RPC=https://polygon-rpc.com
